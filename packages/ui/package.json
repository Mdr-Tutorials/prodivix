{
  "name": "@prodivix/ui",
  "version": "0.1.2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mdr-Tutorials/prodivix.git",
    "directory": "packages/ui"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button/PdxButton.d.ts",
      "import": "./dist/button/PdxButton.js"
    },
    "./link": {
      "types": "./dist/link/PdxLink.d.ts",
      "import": "./dist/link/PdxLink.js"
    },
    "./nav": {
      "types": "./dist/nav/PdxNav.d.ts",
      "import": "./dist/nav/PdxNav.js"
    },
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@prodivix/shared": "workspace:*",
    "@prodivix/themes": "workspace:*",
    "lucide-react": "^1.23.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "sass": "^1.101.0",
    "storybook": "^10.4.6",
    "typescript": "~6.0.3",
    "vite": "^8.1.3"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "7"
  },
  "scripts": {
    "build": "pnpm run clean && vite build && node scripts/prepend-theme-css.mjs && tsc -p tsconfig.json --emitDeclarationOnly",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true})\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  }
}
