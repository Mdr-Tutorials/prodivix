{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "@prodivix/authoring": ["../authoring/dist/index.d.ts"],
      "@prodivix/pir": ["../pir/dist/index.d.ts"],
      "@prodivix/shared": ["../shared/dist/index.d.ts"],
      "@prodivix/shared/*": ["../shared/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../authoring"
    },
    {
      "path": "../pir"
    },
    {
      "path": "../shared"
    }
  ]
}
