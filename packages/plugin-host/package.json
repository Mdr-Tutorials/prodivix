{
  "name": "@prodivix/plugin-host",
  "version": "0.0.1",
  "type": "module",
  "description": "Transport-neutral plugin lifecycle, permissions, and contribution registry for Prodivix",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#host/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true})\"",
    "pretest": "pnpm --filter @prodivix/plugin-contracts build",
    "test": "pnpm run typecheck && vitest --config vitest.config.ts --run",
    "pretest:watch": "pnpm --filter @prodivix/plugin-contracts build",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@prodivix/plugin-contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
