{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prodivix.dev/schemas/theme-manifest.schema.json",
  "title": "Prodivix Theme Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "source", "mode", "semantic"],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9][a-z0-9-]*)+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string"
    },
    "source": {
      "enum": ["official", "custom", "community"]
    },
    "mode": {
      "enum": ["light", "dark", "adaptive"]
    },
    "semantic": {
      "$ref": "#/$defs/tokenTree"
    },
    "product": {
      "$ref": "#/$defs/tokenTree"
    },
    "typography": {
      "$ref": "#/$defs/tokenTree"
    },
    "radius": {
      "$ref": "#/$defs/stringMap"
    },
    "shadow": {
      "$ref": "#/$defs/stringMap"
    },
    "density": {
      "$ref": "#/$defs/tokenTree"
    },
    "motion": {
      "$ref": "#/$defs/tokenTree"
    },
    "fonts": {
      "$ref": "#/$defs/fontRegistry"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preview": {
          "type": "string"
        },
        "license": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "tokenTree": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "number"
          },
          {
            "$ref": "#/$defs/tokenTree"
          }
        ]
      }
    },
    "fontRegistry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["faces"],
      "properties": {
        "faces": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/fontFace"
          }
        }
      }
    },
    "fontFace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "sources"],
      "properties": {
        "family": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[a-zA-Z0-9 ._-]+$"
        },
        "style": {
          "type": "string",
          "pattern": "^(normal|italic|oblique(?: -?\\d+deg(?: -?\\d+deg)?)?)$"
        },
        "display": {
          "enum": ["auto", "block", "swap", "fallback", "optional"]
        },
        "weight": {
          "type": "string",
          "pattern": "^([1-9]00|[1-9]00 [1-9]00|normal|bold)$"
        },
        "stretch": {
          "type": "string",
          "pattern": "^(\\d{1,3}(?:\\.\\d+)?%|\\d{1,3}(?:\\.\\d+)?% \\d{1,3}(?:\\.\\d+)?%)$"
        },
        "unicodeRange": {
          "type": "string",
          "maxLength": 600,
          "pattern": "^U\\+[0-9A-F?]{1,6}(?:-[0-9A-F]{1,6})?(?:,\\s*U\\+[0-9A-F?]{1,6}(?:-[0-9A-F]{1,6})?)*$"
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/fontSource"
          }
        }
      }
    },
    "fontSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "format"],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "enum": ["woff2", "woff"]
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2097152
        }
      }
    }
  }
}
