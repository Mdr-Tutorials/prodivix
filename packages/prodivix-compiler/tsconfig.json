{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "paths": {
      "#src/*": ["./src/*"],
      "@prodivix/pir": ["../pir/src"],
      "@prodivix/shared": ["../shared/src"],
      "@prodivix/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**"
  ],
  "references": [
    {
      "path": "../pir"
    },
    {
      "path": "../shared"
    },
    {
      "path": "../themes"
    },
    {
      "path": "../ui"
    }
  ]
}
