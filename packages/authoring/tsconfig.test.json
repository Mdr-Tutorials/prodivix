{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "@prodivix/diagnostics": ["../diagnostics/dist/index.d.ts"],
      "@prodivix/shared": ["../shared/dist/index.d.ts"],
      "@prodivix/shared/*": ["../shared/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../diagnostics"
    },
    {
      "path": "../shared"
    }
  ]
}
