{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "paths": {
      "@prodivix/runtime-core": ["../runtime-core/src"],
      "@prodivix/runtime-remote": ["../runtime-remote/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"],
  "references": [{ "path": "../runtime-core" }, { "path": "../runtime-remote" }]
}
