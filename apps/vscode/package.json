{
  "name": "@prodivix/vscode",
  "displayName": "prodivix",
  "description": "PIR 节点图支持",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "pir",
        "aliases": [
          "PIR",
          "pir"
        ],
        "extensions": [
          ".pir.json"
        ],
        "configuration": "./src/language/pir.language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "prodivix.previewPIR",
        "title": "PIR: Preview PIR"
      }
    ],
    "debuggers": [
      {
        "type": "prodivix",
        "label": "Pdx Debug",
        "program": "./dist/debugAdapter.js"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "dev": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "echo \"No tests for vscode\" && exit 0"
  },
  "dependencies": {
    "@prodivix/vscode-debugger": "workspace:*"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~26.1.0",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3"
  }
}
