# Native PostgreSQL used by scripts/start-dev.bat and scripts/start-dev-postgres.ps1.
BACKEND_DB_URL=postgres://postgres:postgres@127.0.0.1:55456/prodivix?sslmode=disable

# Required to enable the production Environment/Secret store. Generate 32 random bytes and encode them as base64.
# BACKEND_ENVIRONMENT_SECRET_KEY=<base64-encoded-256-bit-key>

# Optional: folder containing pg_ctl.exe, initdb.exe, psql.exe, and createdb.exe.
# PRODIVIX_PG_BIN=C:\Program Files\PostgreSQL\16\bin
