# Native PostgreSQL used by scripts/start-dev.bat and scripts/start-dev-postgres.ps1.
BACKEND_DB_URL=postgres://postgres:postgres@127.0.0.1:55456/prodivix?sslmode=disable
# BACKEND_ASSET_BLOB_ORPHAN_RETENTION=168h
# BACKEND_ASSET_BLOB_SWEEP_INTERVAL=1h
# BACKEND_ASSET_BLOB_SWEEP_WORKSPACE_LIMIT=32
# BACKEND_ASSET_BLOB_SWEEP_BLOB_LIMIT=256

# Configure one active Environment/Secret KMS provider. Static key material is intended for development and migration.
# BACKEND_ENVIRONMENT_SECRET_KMS_ACTIVE_KEY_ID=key-2026-07
# BACKEND_ENVIRONMENT_SECRET_KMS_KEYS={"key-2026-01":"<base64-encoded-256-bit-key>","key-2026-07":"<base64-encoded-256-bit-key>"}
# Managed-cloud alternative: exact immutable key ARNs and short-lived AWS credentials. Static keys, if retained, are decrypt-only migration sources.
# BACKEND_ENVIRONMENT_SECRET_KMS_PROVIDER=aws-kms
# BACKEND_ENVIRONMENT_SECRET_KMS_AWS_REGION=us-east-1
# BACKEND_ENVIRONMENT_SECRET_KMS_AWS_KEY_ARNS={"key-2026-07":"arn:aws:kms:us-east-1:111122223333:key/00000000-0000-0000-0000-000000000000"}
# BACKEND_ENVIRONMENT_SECRET_KMS_TIMEOUT=5s
# Optional only while migrating legacy direct-cipher rows. A lone legacy key maps to active key id legacy-v1.
# BACKEND_ENVIRONMENT_SECRET_KEY=<legacy-base64-encoded-256-bit-key>
# BACKEND_ENVIRONMENT_SECRET_ROTATION_INTERVAL=5m
# BACKEND_ENVIRONMENT_SECRET_ROTATION_BATCH_SIZE=64

# Optional short-lived Backend -> Control Plane principal projection for isolated authenticated reads.
# REMOTE_RUNNER_EXECUTION_AUTHORITY_TTL=2m

# Remote Control Plane Terminal recovery. Static-key-ring is the compatibility/development default.
# REMOTE_TERMINAL_STATE_ACTIVE_KEY_ID=terminal-2026-07
# REMOTE_TERMINAL_STATE_KEYS_JSON={"terminal-2026-01":"<base64-encoded-256-bit-key>","terminal-2026-07":"<base64-encoded-256-bit-key>"}
# Managed KMS production alternative. In this mode the static JSON, if retained, is decrypt-only PRT1 migration material.
# REMOTE_TERMINAL_STATE_KMS_PROVIDER=aws-kms
# REMOTE_TERMINAL_STATE_KMS_AWS_REGION=us-east-1
# REMOTE_TERMINAL_STATE_KMS_AWS_KEY_ARNS_JSON={"terminal-2026-07":"arn:aws:kms:us-east-1:111122223333:key/mrk-00000000000000000000000000000000"}
# REMOTE_TERMINAL_STATE_KMS_TIMEOUT_MS=5000
# For cross-Region recovery, deploy the same logical key id with the exact related MRK replica ARN and local region in each region.
# REMOTE_TERMINAL_ACCESS_TTL_MS=60000

# Optional all-or-none regional Control Plane traffic fence. Every region shares this strongly consistent authority database.
# REMOTE_CONTROL_PLANE_DEPLOYMENT_ID=production
# REMOTE_CONTROL_PLANE_REGION_ID=us-east-1
# REMOTE_CONTROL_PLANE_INITIAL_ACTIVE_REGION_ID=us-east-1
# REMOTE_CONTROL_PLANE_TRAFFIC_DATABASE_URL=postgres://prodivix_traffic:<password>@traffic-authority.internal:5432/prodivix_traffic?sslmode=require

# Optional: folder containing pg_ctl.exe, initdb.exe, psql.exe, and createdb.exe.
# PRODIVIX_PG_BIN=C:\Program Files\PostgreSQL\16\bin
