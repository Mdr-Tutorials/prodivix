{
  "$schema": "https://prodivix.dev/schemas/plugin-manifest-v1.schema.json",
  "schemaVersion": "1.0",
  "id": "@prodivix/plugin-antd",
  "displayName": "Ant Design",
  "description": "Official Ant Design component, rendering, and code generation integration.",
  "version": "0.1.0",
  "publisher": "prodivix",
  "license": "MIT",
  "engines": {
    "prodivix": ">=0.1.0 <1.0.0"
  },
  "entrypoints": {
    "runtime": {
      "path": "./dist/runtime.js"
    }
  },
  "activationEvents": [
    {
      "type": "contribution.use",
      "point": "paletteContribution",
      "contributionId": "antd.components"
    },
    {
      "type": "contribution.use",
      "point": "codegenPolicy",
      "contributionId": "antd.react-codegen"
    }
  ],
  "capabilities": [
    {
      "id": "extension.register",
      "scope": "externalLibrary",
      "reason": "Register the Ant Design external library descriptor."
    },
    {
      "id": "extension.register",
      "scope": "paletteContribution",
      "reason": "Add Ant Design components to the component palette."
    },
    {
      "id": "extension.register",
      "scope": "renderPolicy",
      "reason": "Provide safe canvas rendering rules for Ant Design components."
    },
    {
      "id": "extension.register",
      "scope": "codegenPolicy",
      "reason": "Generate Ant Design imports and component usage for supported targets."
    },
    {
      "id": "network.request",
      "scope": "official-package-cdn",
      "reason": "Load the configured Ant Design package artifacts."
    }
  ],
  "contributes": [
    {
      "id": "antd.library",
      "point": "externalLibrary",
      "contractVersion": "1.0",
      "source": {
        "kind": "resource",
        "path": "./contributions/antd.external-library.json"
      }
    },
    {
      "id": "antd.components",
      "point": "paletteContribution",
      "contractVersion": "1.0",
      "source": {
        "kind": "resource",
        "path": "./contributions/antd.palette.json"
      }
    },
    {
      "id": "antd.canvas-rendering",
      "point": "renderPolicy",
      "contractVersion": "1.0",
      "source": {
        "kind": "resource",
        "path": "./contributions/antd.render-policy.json"
      }
    },
    {
      "id": "antd.react-codegen",
      "point": "codegenPolicy",
      "contractVersion": "1.0",
      "source": {
        "kind": "inline",
        "descriptor": {
          "target": "react",
          "implementationId": "antd.react-codegen"
        }
      }
    }
  ],
  "metadata": {
    "categories": ["Component libraries"],
    "tags": ["official", "components", "react", "antd"]
  }
}
